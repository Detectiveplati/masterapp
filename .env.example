# Auth bypass — FOR LOCAL TESTING ONLY. Must be false/removed in production.
BYPASS_AUTH=false

# Server Configuration
PORT=3000
NODE_ENV=production   # Set to 'production' on Railway

# Maintenance Dashboard Database (Mongoose) — use MongoDB Atlas URI on Railway
MAINTENANCE_MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/central_kitchen_maintenance?retryWrites=true&w=majority

# Kitchen Temp Log Database (native MongoDB driver) — use MongoDB Atlas URI on Railway
TEMPLOG_MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net
TEMPLOG_DB_NAME=kitchenlog
ORDER_MANAGER_MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net
ORDER_MANAGER_DB_NAME=kitchenlog
ORDER_MANAGER_MONGODB_APP_NAME=masterapp-order-manager
ORDER_MANAGER_MONGODB_MAX_POOL_SIZE=20
ORDER_MANAGER_MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
ORDER_MANAGER_BASE_URL=
ORDER_MANAGER_LOGIN_URL=
ORDER_MANAGER_REPORT_URL=
ORDER_MANAGER_USERNAME=
ORDER_MANAGER_PASSWORD=
ORDER_MANAGER_SAVE_FILES=false
ORDER_MANAGER_HEADLESS=true
ORDER_MANAGER_TIMEOUT_MS=60000
ORDER_MANAGER_SCHEDULE_ENABLED=true
ORDER_MANAGER_SCHEDULE_TIMEZONE=Asia/Singapore
ORDER_MANAGER_SIMULATE_REFRESH_DATE=
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# Railway deploy note:
# Railway healthcheck uses /api/health.
# In production there is no localhost MongoDB fallback for order-manager.

# Cloudinary — required for image uploads (equipment issues, maintenance records, procurement)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# QR Code Base URL — set to your Railway app URL so QR codes link correctly
# e.g. https://your-app.up.railway.app
# Leave unset to auto-detect from request host (works on Railway with trust proxy)
QR_BASE_URL=

# QR Code settings
QR_SIZE=300
QR_ERROR_CORRECTION=M

# Notification Settings (optional)
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
# SMS_API_KEY=your-sms-api-key

# LoRa TCP Gateway — internal port the server binds to
LORA_TCP_PORT=4001
# Railway TCP Proxy — set these to the hostname/port Railway assigns after adding TCP Proxy in the dashboard
# Leave blank for local development (gateway.html will fall back to browser hostname:4001)
LORA_TCP_PROXY_HOST=
LORA_TCP_PROXY_PORT=

# Security — JWT secret for authentication cookies (required in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-jwt-secret-replace-with-random-string-in-production

# SESSION_SECRET=your-secret-key-generate-a-random-string
